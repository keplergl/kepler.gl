{
  "name": "@kepler.gl/ai-assistant",
  "author": "Xun Li<lixun910@gmail.com>",
  "version": "3.3.0-alpha.0",
  "description": "kepler.gl AI assistant",
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "keywords": [
    "babel",
    "es6",
    "react",
    "webgl",
    "visualization",
    "deck.gl"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/keplergl/kepler.gl.git"
  },
  "scripts": {
    "build": "rm -fr dist && babel src --out-dir dist --source-maps inline --extensions '.ts,.tsx,.js,.jsx' --ignore '**/*.d.ts'",
    "build:umd": "NODE_OPTIONS=--openssl-legacy-provider webpack --config ./webpack/umd.js --progress --env.prod",
    "build:types": "tsc --project ./tsconfig.production.json",
    "prepublishOnly": "babel-node ../../scripts/license-header/bin --license ../../FILE-HEADER && yarn build && yarn build:types",
    "stab": "mkdir -p dist && touch dist/index.js"
  },
  "files": [
    "dist",
    "umd"
  ],
  "dependencies": {
    "@ai-sdk/anthropic": "^1.2.11",
    "@ai-sdk/deepseek": "^0.2.14",
    "@ai-sdk/google": "^1.2.18",
    "@ai-sdk/openai-compatible": "^1.0.18",
    "@ai-sdk/react": "^3.0.118",
    "@ai-sdk/xai": "^1.2.16",
    "@kepler.gl/actions": "3.3.0-alpha.0",
    "@kepler.gl/components": "3.3.0-alpha.0",
    "@kepler.gl/constants": "3.3.0-alpha.0",
    "@kepler.gl/duckdb": "3.3.0-alpha.0",
    "@kepler.gl/layers": "3.3.0-alpha.0",
    "@kepler.gl/localization": "3.3.0-alpha.0",
    "@kepler.gl/processors": "3.3.0-alpha.0",
    "@kepler.gl/reducers": "3.3.0-alpha.0",
    "@kepler.gl/schemas": "3.3.0-alpha.0",
    "@kepler.gl/table": "3.3.0-alpha.0",
    "@kepler.gl/types": "3.3.0-alpha.0",
    "@kepler.gl/utils": "3.3.0-alpha.0",
    "@sqlrooms/ai-config": "*",
    "@sqlrooms/ai-core": "*",
    "@sqlrooms/ai-settings": "*",
    "@sqlrooms/room-store": "*",
    "@sqlrooms/ui": "*",
    "ai": "^6.0.154",
    "apache-arrow": ">=15.0.0",
    "color-interpolate": "^1.0.5",
    "echarts": "^5.6.0",
    "echarts-for-react": "^3.0.2",
    "ollama-ai-provider-v2": "^0.0.5",
    "react-intl": "^6.3.0",
    "zod": "^4.1.8"
  },
  "nyc": {
    "sourceMap": false,
    "instrument": false
  },
  "maintainers": [
    "Xun Li <lixun910@gmail.com>",
    "Igor Dykhta <dikhta.igor@gmail.com>"
  ],
  "engines": {
    "node": ">=20"
  },
  "volta": {
    "node": "20.19.3",
    "yarn": "4.4.0"
  },
  "packageManager": "yarn@4.4.0"
}
